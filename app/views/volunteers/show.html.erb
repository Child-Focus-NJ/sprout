<main class="volunteer-page">
<h1 class="page-title"><%= @volunteer.full_name %></h1>
<nav class="page-nav card" aria-label="Page">
  <%= link_to "← Back to volunteer list", volunteers_path, class: "button-link" %>
</nav>

<section id="contact-info" class="card status-panel">
  <h2 class="section-heading">Contact</h2>
  <% if @volunteer.phone.present? %>
    <% normalized_phone = @volunteer.phone.to_s.gsub(/\D/, "") %>
    <% phone_invalid = normalized_phone.length < 10 %>
    <p class="<%= phone_invalid ? 'bad-phone phone-invalid' : '' %>">
      Phone: <%= @volunteer.phone %>
      <% if phone_invalid %>
        <span>— Phone number may be invalid or unreachable</span>
      <% end %>
    </p>
  <% elsif @volunteer.email.present? %>
    <p>Email: <%= @volunteer.email %></p>
  <% end %>
</section>

<%= render "status_management" %>

<section id="actions" class="card status-panel">
  <h2 class="section-heading">Actions</h2>
  <div class="action-toolbar">
    <%= link_to "Send SMS", sms_volunteer_path(@volunteer), class: "button-link" %>
    <%= form_with url: send_application_volunteer_path(@volunteer), method: :post, html: { class: "inline-action-form" } do %>
      <button type="submit">Send Application</button>
    <% end %>
    <% if @volunteer.application_sent? %>
      <%= form_with url: mark_submitted_volunteer_path(@volunteer), method: :patch, html: { class: "inline-action-form" } do %>
        <button type="submit">Mark as Submitted</button>
      <% end %>
    <% end %>
    <div class="delete-action">
      <%= button_to "Delete", volunteer_path(@volunteer), method: :delete, data: { confirm: "Are you sure?" }, class: "btn-delete" %>
    </div>
  </div>

  <div class="note-entry-panel">
    <h3 class="subsection-heading">Add a note</h3>
    <%= form_with url: add_note_volunteer_path(@volunteer), method: :post, html: { class: "note-form", id: "add-note-form" } do %>
      <label for="note" class="sr-only">Note text</label>
      <textarea id="note" name="note" rows="4" maxlength="1000" placeholder="Type your note here, then press Add Note."></textarea>
      <p class="subtle">Maximum 1000 characters.</p>
      <div class="mt-2">
        <button type="submit" class="btn-note">Add Note</button>
      </div>
    <% end %>
  </div>
</section>

<section id="communications" class="card status-panel">
  <h2 class="section-heading">SMS communication history</h2>
  <% @volunteer.communications.sms.recent.each do |comm| %>
    <div class="communication-entry">
      <div>
        <strong>SMS</strong>
        <span class="delivery-status"><%= comm.status %></span>
      </div>
      <% if comm.sent_at.present? %>
        <time datetime="<%= comm.sent_at.iso8601 %>"><%= comm.sent_at.strftime("%Y-%m-%d %H:%M") %></time>
      <% end %>
      <div class="content"><%= comm.body.to_s %></div>
    </div>
  <% end %>
  <% if @volunteer.communications.sms.recent.empty? %>
    <p class="subtle">No SMS messages yet.</p>
  <% end %>
</section>

<section class="timeline card status-panel" data-timeline="true">
  <h2 class="section-heading">Timeline</h2>
  <p class="help-text">Reminders, info sessions, and notes in one place. Use the filter to show only notes.</p>

  <%= form_with url: volunteer_path(@volunteer), method: :get, local: true, html: { class: "timeline-filter-form" } do %>
    <label for="filter">Show</label>
    <select id="filter" name="filter" onchange="this.form.submit()" class="input-large">
      <option value="all" <%= "selected" if @timeline_filter == "all" %>>All activity</option>
      <option value="notes" <%= "selected" if @timeline_filter == "notes" %>>Notes only</option>
    </select>
  <% end %>

  <% @timeline_entries.each do |entry| %>
    <% css_class = case entry[:kind]
    when :note then "entry note-entry"
    when :email then "entry communication-email"
    when :sms then "entry communication-sms"
    when :info_session then "entry info-session-entry"
    else "entry"
    end %>
    <div class="<%= css_class %>">
      <strong><%= entry[:kind].to_s.humanize %></strong>
      <div><%= entry[:text] %></div>
      <% if entry[:byline].present? %>
        <div>By <%= entry[:byline] %></div>
      <% end %>
      <% if entry[:time].present? %>
        <time datetime="<%= entry[:time].iso8601 %>"><%= entry[:time].strftime("%m/%d/%Y %H:%M") %></time>
      <% end %>
    </div>
  <% end %>
</section>

<script>
  (function () {
    const filter = document.getElementById("filter");
    if (!filter) return;

    const applyFilter = () => {
      const notesOnly = filter.value === "notes";
      document.querySelectorAll(".timeline .entry").forEach((entry) => {
        const isNote = entry.classList.contains("note-entry");
        entry.style.display = notesOnly && !isNote ? "none" : "";
      });
    };

    filter.addEventListener("change", applyFilter);
    applyFilter();
  })();
</script>
</main>
