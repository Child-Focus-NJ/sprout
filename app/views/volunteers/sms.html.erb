<main class="volunteer-page">
<nav class="page-nav page-nav--back" aria-label="Back">
  <%= back_nav_link volunteer_path(@volunteer), "Back to profile" %>
</nav>

<h1 class="page-title">Send SMS</h1>

<section id="sms-recipient" class="card">
  <h2>Sending to <%= @volunteer.full_name %></h2>
  <% if @volunteer.phone.present? %>
    <p>Phone: <%= @volunteer.phone %></p>
  <% end %>

  <% if @volunteer.communications.sms.exists? %>
    <h3>Previous messages</h3>
    <% @volunteer.communications.sms.recent.each do |comm| %>
      <div class="communication-entry">
        <time datetime="<%= comm.sent_at&.iso8601 || comm.created_at.iso8601 %>">
          <%= (comm.sent_at || comm.created_at).strftime("%Y-%m-%d %H:%M") %>
        </time>
        <div class="content"><%= comm.body.to_s %></div>
      </div>
    <% end %>
  <% else %>
    <p>No previous messages sent yet.</p>
  <% end %>
</section>

<section id="sms-compose" class="card sms-compose-form" aria-labelledby="sms-compose-heading">
  <h2 id="sms-compose-heading" class="subsection-heading">Your message</h2>

  <%= form_with url: send_sms_volunteer_path(@volunteer), method: :post, html: { class: "grid gap-3 m-0" } do %>
    <div class="grid gap-1.5">
      <label for="message">Message</label>
      <textarea id="message" name="message" rows="6" maxlength="320"><%= @message %></textarea>
    </div>

    <div id="sms-character-count">
      Character count: <span id="sms-char-count-value"><%= @message.to_s.length %></span> / 320
    </div>
    <p class="subtle">Maximum 320 characters.</p>

    <div>
      <button type="submit">Send</button>
    </div>
  <% end %>
</section>

<script>
  (function () {
    const textarea = document.getElementById("message");
    const valueEl = document.getElementById("sms-char-count-value");
    if (!textarea || !valueEl) return;

    const update = () => { valueEl.textContent = String(textarea.value.length); };
    textarea.addEventListener("input", update);
    update();
  })();
</script>

</main>

